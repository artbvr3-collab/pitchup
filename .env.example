# PITCHUP — environment variables
# Copy to .env.local and fill in. Never commit .env.local.
#
# All env vars are validated at startup via Zod in src/shared/config/env.ts
# (added in Layer 1 — see docs/ROADMAP.md). A missing or invalid var fails
# the process; there are no implicit defaults.
#
# Layer 1 (Auth) consumes DATABASE_URL, AUTH_SECRET, AUTH_GOOGLE_ID,
# AUTH_GOOGLE_SECRET. All four are required — Zod will reject startup
# without them. The values below are dev placeholders that satisfy the
# schema; replace before running against a real DB / OAuth client.

# ──────────────────────────────────────────────
# APP
# ──────────────────────────────────────────────
# Public base URL of this deployment. Used for absolute links in emails and OG tags.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated allowed Origins for CSRF same-origin check
# (see docs/spec/pitchup-spec-global.md → "CSRF / same-origin").
# Local dev: http://localhost:3000
# Prod: https://pitchup.online
# Staging: https://staging.pitchup.online
ALLOWED_ORIGINS=http://localhost:3000

# ──────────────────────────────────────────────
# DATABASE — added at Layer 1 (User table), used Layer 2+
# ──────────────────────────────────────────────
# Full Postgres connection string. Neon / Supabase / local — same shape.
DATABASE_URL=postgresql://pitchup:pitchup@localhost:5432/pitchup?schema=public

# ──────────────────────────────────────────────
# AUTH (Auth.js v5) — added at Layer 1
# ──────────────────────────────────────────────
# AUTH_SECRET — random 32+ char string. Generate with: openssl rand -base64 32
AUTH_SECRET=dev_placeholder_replace_with_openssl_rand_base64_32

# Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI in Google Console:
#   Local: http://localhost:3000/api/auth/callback/google
#   Prod:  https://pitchup.online/api/auth/callback/google
AUTH_GOOGLE_ID=dev_placeholder_replace_with_google_oauth_client_id
AUTH_GOOGLE_SECRET=dev_placeholder_replace_with_google_oauth_client_secret

# ──────────────────────────────────────────────
# EMAIL (Resend) — added at Layer 7b. See ADR-0004.
# ──────────────────────────────────────────────
# Transport selector. Leave UNSET (or =console) for the console adapter, which
# logs emails instead of sending — the dev default, even if a key is present.
# Set =resend to send real mail; then RESEND_API_KEY + RESEND_FROM are REQUIRED
# (composition throws at startup otherwise).
# EMAIL_TRANSPORT=resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM=PITCHUP <noreply@pitchup.online>

# ──────────────────────────────────────────────
# REALTIME CHAT (Ably) — added at Layer 5.5. See ADR-0005.
# ──────────────────────────────────────────────
# Both OPTIONAL. Absent → chat runs on polling only (the realtime publisher is
# a no-op and the client subscribe hook does nothing). Set both to enable the
# <1s-latency overlay. Realtime is an enhancement, never the source of truth.
#   - ABLY_API_KEY: server-side FULL key (publish capability). Used by API
#     routes for fan-out only. NEVER exposed to the client.
#   - NEXT_PUBLIC_ABLY_SUBSCRIBE_KEY: subscribe-only key
#     (capability {"*": ["subscribe", "history"]}). Shipped in the client
#     bundle — safe because it cannot publish.
# Create both in the Ably dashboard (one app, two API keys with different
# capabilities). https://ably.com/
# ABLY_API_KEY=xxxxxxxx.xxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_ABLY_SUBSCRIBE_KEY=xxxxxxxx.xxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────
# VENUE PHOTO STORAGE (Cloudflare R2, S3-compatible)
# ──────────────────────────────────────────────
# All OPTIONAL. Absent → the admin venue photo UPLOAD button is disabled (the
# route returns 503 photo_storage_unconfigured) and admins paste a Photo URL by
# hand instead. Set ALL FIVE to enable in-admin uploads.
#
# Setup (Cloudflare dashboard → R2):
#   1. Create a bucket, e.g. "pitchup-venues".
#   2. Give it public access: enable the r2.dev dev URL, OR connect a custom
#      domain (e.g. images.pitchup.online). That public origin = R2_PUBLIC_BASE_URL.
#   3. Manage API tokens → Create token (Object Read & Write, this bucket) →
#      copy the Access Key ID + Secret Access Key. The Account ID is shown on
#      the R2 overview page (also in the S3 endpoint).
#
# R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# R2_BUCKET=pitchup-venues
# R2_PUBLIC_BASE_URL=https://images.pitchup.online
