# PITCHUP — Caddy reverse proxy (Layer 10b).
#
# Topology: Cloudflare (proxied, SSL mode "Full (strict)") → Caddy (here) → app:3000.
# Origin TLS is a Cloudflare ORIGIN CERTIFICATE (15-year, trusted only by
# Cloudflare) mounted read-only at /etc/caddy/certs. No ACME here: the orange
# cloud would intercept HTTP-01/TLS-ALPN challenges. (Auto-cert alternative via
# the Cloudflare DNS-01 challenge needs a custom Caddy build — see the runbook.)
#
# This service runs ONLY under the `prod` compose profile, so a local
# `docker compose up` (without COMPOSE_PROFILES=prod) skips Caddy and you reach
# the app directly on localhost:3000.
#
# RELATED DOCS: docs/adr/0006-deploy-topology.md, docs/deploy-runbook.md

{
	# No admin API — smaller attack surface; config reloads via container restart.
	admin off
}

{$CADDY_SITE_ADDRESS:pitchup.online} {
	encode zstd gzip

	# Cloudflare Origin Certificate (cert + private key, mounted read-only).
	tls /etc/caddy/certs/pitchup.online.pem /etc/caddy/certs/pitchup.online.key

	# The app standalone server. Caddy sets X-Forwarded-{For,Proto,Host}, which
	# Auth.js v5 honours (trustHost: true) for correct callback URLs.
	reverse_proxy app:3000

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "SAMEORIGIN"
		-Server
	}
}
