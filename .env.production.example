# PITCHUP — production environment template (Layer 10).
# Copy to `.env` on the VPS (next to docker-compose.yml) and fill in real values.
#   cp .env.production.example .env
# `.env` is git-ignored and read by docker compose for variable substitution.
# Never commit real secrets.

# ── Compose profile ──────────────────────────────────────────────────────────
# `prod` activates the Caddy reverse proxy (80/443). Set this ON THE VPS so a
# plain `docker compose up -d` includes Caddy. Leave UNSET locally to skip Caddy
# and reach the app directly on localhost:3000.
COMPOSE_PROFILES=prod

# ── Container image (set by CI / deploy) ─────────────────────────────────────
# The image the `app` service runs. Image names MUST be all-lowercase.
#   - LOCAL smoke (docker compose up --build): keep `pitchup:local`.
#   - PRODUCTION: your GHCR image, e.g. ghcr.io/<your-github-username>/pitchup:latest
#     (lowercase owner; CI updates the tag on each deploy).
APP_IMAGE=pitchup:local

# ── Cron image (set by CI / deploy) ──────────────────────────────────────────
# Separate tsx-capable image for the 4 scheduled jobs, invoked on demand by the
# host crontab via `docker compose run --rm cron <command>`. Lowercase, like above.
#   - LOCAL:      keep `pitchup-cron:local`.
#   - PRODUCTION: ghcr.io/<your-github-username>/pitchup-cron:latest
CRON_IMAGE=pitchup-cron:local

# ── Self-hosted Postgres (db service) ────────────────────────────────────────
POSTGRES_USER=pitchup
POSTGRES_DB=pitchup
# REQUIRED — generate a strong value, e.g. `openssl rand -base64 32`.
POSTGRES_PASSWORD=

# ── Auth (Auth.js v5 / Google OAuth) ─────────────────────────────────────────
# REQUIRED — `openssl rand -base64 32` (min 32 chars).
AUTH_SECRET=
# REQUIRED — from Google Cloud Console. The OAuth client's Authorized redirect
# URI must include: https://pitchup.online/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Absolute callback base behind the reverse proxy (Auth.js v5). Match the domain.
AUTH_URL=https://pitchup.online

# ── Reverse proxy (Caddy) ────────────────────────────────────────────────────
# The site address Caddy serves. The Cloudflare Origin Certificate must cover it
# and be saved on the VPS as caddy/certs/pitchup.online.{pem,key}.
CADDY_SITE_ADDRESS=pitchup.online

# ── Public base URL ──────────────────────────────────────────────────────────
# Baked into the client bundle at BUILD time (CI build-arg) AND read server-side
# for email deep links. Keep both occurrences identical to the canonical domain.
NEXT_PUBLIC_APP_URL=https://pitchup.online

# ── Email (Resend) — optional; defaults to console transport ────────────────
# Set EMAIL_TRANSPORT=resend to enable real sends (then the two below are required).
EMAIL_TRANSPORT=console
RESEND_API_KEY=
RESEND_FROM=

# ── Realtime chat (Ably) — optional; absent → polling carries chat ───────────
# ABLY_API_KEY: server-side full key (fan-out). NEXT_PUBLIC_ABLY_SUBSCRIBE_KEY:
# subscribe-only key, BAKED into the client bundle at build time (CI build-arg).
ABLY_API_KEY=
NEXT_PUBLIC_ABLY_SUBSCRIBE_KEY=
