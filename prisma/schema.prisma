// PITCHUP ‚Äî Prisma schema
// Source of truth for the spec: docs/spec/pitchup-app-map.md ‚Üí "Main entities"
//                              docs/spec/pitchup-spec-global.md ‚Üí "Authentication", "Slot math", "Field surface", "Cover venue"
//                              docs/spec/pitchup-spec-match.md ‚Üí "Match states"
// Layers: 1 (User), 2 (Match + Venue read-only), 4 (JoinRequest + Watch),
//         5 (ChatMessage), 7 (Notification), 7b (ReminderSent), 9 (AdminAction,
//         AdminMatchDeletion, Report), /chats (ChatRead).
// Subsequent layers grow this file (Like ‚Äî see app-map ERD).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Application user. Row is created only when onboarding completes ‚Äî
/// before that, an OAuth-authenticated visitor has no DB record.
/// See docs/spec/pitchup-spec-global.md ‚Üí "Onboarding guard".
model User {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  googleSub          String    @unique @map("google_sub")
  email              String
  name               String
  avatarUrl          String    @map("avatar_url")
  contactInfo        String?   @map("contact_info")
  emailNotifications Boolean   @default(true) @map("email_notifications")
  isAdmin            Boolean   @default(false) @map("is_admin")
  banned             Boolean   @default(false)
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  captainMatches Match[]        @relation("MatchCaptain")
  joinRequests   JoinRequest[]
  watches        Watch[]
  chatMessages   ChatMessage[]  @relation("ChatMessageAuthor")
  chatReads      ChatRead[]
  notifications  Notification[]
  remindersSent  ReminderSent[]

  adminActionsActed    AdminAction[] @relation("AdminActionActor")
  adminActionsReceived AdminAction[] @relation("AdminActionTarget")

  reportsMade     Report[] @relation("ReportReporter")
  reportsReceived Report[] @relation("ReportTargetUser")
  reportsReviewed Report[] @relation("ReportReviewer")

  likesGiven    Like[] @relation("LikeGiver")
  likesReceived Like[] @relation("LikeReceiver")

  @@map("users")
}

/// Physical pitch / venue where matches are played. Admin-managed.
/// Fields per docs/spec/pitchup-app-map.md ‚Üí "Main entities" ‚Üí Venue row.
/// `surface` is text[] (a venue may offer both grass and hard) ‚Äî app-level
/// validation against the tokens `grass` / `hard`, not a Postgres enum
/// (see global.md ‚Üí "Field surface").
/// `cover_id` is a slug into the cover palette, deterministic by venue.id
/// when not explicitly set (see global.md ‚Üí "Cover venue").
/// `active = false` hides the venue from new-match creation but does not
/// affect existing matches (see personal.md ‚Üí "/admin/venues").
model Venue {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  address       String
  lat           Float    @db.DoublePrecision
  lng           Float    @db.DoublePrecision
  googleMapsUrl String?  @map("google_maps_url")
  photoUrl      String?  @map("photo_url")
  surface       String[] @db.Text
  coverId       String   @map("cover_id") @db.VarChar(40)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  matches Match[]

  @@map("venues")
}

/// A scheduled football match. Captain hosts; players join via JoinRequest
/// (added in Layer 4). Status is computed on-read from `startTime`, `duration`,
/// and `cancelledAt` ‚Äî there is NO status column (see match.md ‚Üí "Match states").
///
/// Slot math: `filled = 1 (captain) + captainCrew.length + Œ£(accepted JoinRequest)` ‚Äî
/// canonical formula in global.md ‚Üí "Slot math". Always via `computeSlots(match)`.
///
/// `coverId` is a snapshot of `venue.coverId` taken at INSERT time. Changing the
/// venue's cover later does NOT propagate to existing matches (intentional
/// denormalization; see app-map.md audit notes + global.md ‚Üí "Cover venue").
///
/// `captainCrew` is `NOT NULL DEFAULT '{}'` ‚Äî empty array means an open match
/// with no stub players. `.length` is always safe.
///
/// `surface` validated app-side against `grass` / `hard` (not a Postgres enum;
/// see global.md ‚Üí "Field surface").
model Match {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  captainId          String    @map("captain_id") @db.Uuid
  venueId            String    @map("venue_id") @db.Uuid
  startTime          DateTime  @map("start_time") @db.Timestamptz(6)
  duration           Int
  totalSpots         Int       @map("total_spots") @db.SmallInt
  price              Int
  surface            String
  studsAllowed       Boolean   @map("studs_allowed")
  fieldBooked        Boolean   @default(false) @map("field_booked")
  description        String?
  descriptionHidden  Boolean   @default(false) @map("description_hidden")
  captainCrew        String[]  @default([]) @map("captain_crew") @db.Text
  cancelledAt        DateTime? @map("cancelled_at") @db.Timestamptz(6)
  cancelReason       String?   @map("cancel_reason")
  cancelReasonHidden Boolean   @default(false) @map("cancel_reason_hidden")
  coverId            String    @map("cover_id") @db.VarChar(40)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  captain       User           @relation("MatchCaptain", fields: [captainId], references: [id])
  venue         Venue          @relation(fields: [venueId], references: [id])
  joinRequests  JoinRequest[]
  watches       Watch[]
  chatMessages  ChatMessage[]
  chatReads     ChatRead[]
  notifications Notification[]
  remindersSent ReminderSent[]
  reports       Report[]
  likes         Like[]

  @@index([startTime])
  @@index([venueId])
  @@index([captainId])
  @@map("matches")
}

/// A player's request to join a match. UNIQUE(match_id, user_id) ‚Äî one row per
/// pair. Re-apply after rejected/cancelled/left/kicked is an UPDATE ‚Üí pending
/// (not a new INSERT). Statuses `accepted` and `pending` count as active; the
/// rest are terminal (history kept for Section Past and re-apply validation).
///
/// `autoReason` is non-null only for system-driven rejects: `match_started`
/// (cron) or `match_cancelled` (mass-reject on captain Cancel). Captain reject
/// uses `auto_reason = NULL`. Spec: match.md ‚Üí "Player match states",
/// "Auto-rejected pending are distinguishable by auto_reason".
///
/// `guestCount` 0..4 ‚Äî anonymous +N companions; inseparable from the host
/// (Leave/Kick frees the whole 1+N group). Spec: global.md ‚Üí "Guests (+N on join)".
model JoinRequest {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  matchId    String   @map("match_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  status     String
  guestCount Int      @default(0) @map("guest_count") @db.SmallInt
  message    String?
  autoReason String?  @map("auto_reason")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([matchId, userId])
  @@index([matchId, status])
  @@index([userId])
  @@map("join_requests")
}

/// "Notify me when a spot opens" flag on a `(user, match)` pair. Composite PK,
/// no separate id. Created only on a full match (backend guard in `POST /watch`,
/// Layer 5+); deleted on Join (same tx as JoinRequest UPSERT), Approve (same tx),
/// and `notify watching` slot-freed sub-operation. Spec: match.md ‚Üí "Watching
/// logic", app-map ERD ‚Üí Watch.
model Watch {
  matchId   String   @map("match_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@id([matchId, userId])
  @@index([userId])
  @@map("watches")
}

/// Per-match chat message. Source of truth: docs/spec/pitchup-spec-match.md ‚Üí
/// "Tab Chat" and docs/spec/pitchup-app-map.md ‚Üí ChatMessage entity.
///
/// `author_id` uses ON DELETE RESTRICT ‚Äî messages from banned or deleted users
/// are never physically removed; the render layer resolves the name/avatar and
/// falls back to `[Removed user]` if the profile is gone or banned (match.md ¬ß220).
///
/// `deleted_at` enables captain soft-delete (match.md ¬ß225 "[Delete]" action).
/// Hard-delete is intentionally omitted: moderation history must survive even
/// when the match is Cancelled, and the captain retains moderation rights.
///
/// Composite index on `(match_id, created_at)` drives both the ordered chat feed
/// and the `since`-cursor used by `GET /api/matches/:id/state?since=ISO`.
model ChatMessage {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  matchId   String    @map("match_id") @db.Uuid
  authorId  String    @map("author_id") @db.Uuid
  text      String    @db.VarChar(2000)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  match  Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  author User  @relation("ChatMessageAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([matchId, createdAt])
  @@map("chat_messages")
}

/// Per-(user, match) chat read cursor ‚Äî the source of truth for the unread
/// dot on `/chats`. Composite PK `(matchId, userId)`, no separate id; one row
/// per pair, created lazily on the first Tab Chat open (UPSERT
/// `last_read_at = now()`). Source of truth: docs/spec/pitchup-spec-personal.md
/// ‚Üí "/chats" ‚Üí "Unread chat dots ‚Äî data model" + app-map ERD ‚Üí ChatRead.
///
/// Unread is computed on-read (no stored flag): a match has unread messages
/// for the user iff a non-deleted ChatMessage exists with
/// `created_at > last_read_at AND author_id != user_id` (own messages never
/// count; absent row ‚áí every foreign message is unread).
///
/// `last_read_at` has NO `@default` ‚Äî it is always written explicitly by the
/// service (mark-as-read UPSERT), never defaulted at INSERT.
///
/// onDelete Cascade on BOTH relations ‚Äî this is a disposable read cursor with
/// no history value (unlike JoinRequest, which Restricts on the user to keep
/// "you left" history). If a match is hard-deleted (admin, Layer 9c) or a user
/// is ever hard-removed, the cursor should vanish, not block. Same rationale as
/// Notification / ReminderSent.
model ChatRead {
  matchId    String   @map("match_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  lastReadAt DateTime @map("last_read_at") @db.Timestamptz(6)

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([matchId, userId])
  @@index([userId])
  @@map("chat_reads")
}

/// In-app inbox item (Updates panel). One row per notification event; for a
/// subset of types it is also mirrored to email / browser push in Layer 7b.
/// Source of truth: docs/spec/pitchup-app-map.md ‚Üí "Notification" +
/// docs/spec/pitchup-spec-global.md ‚Üí "Notifications" / "Polling sync".
///
/// `type` is a `text` column app-validated against NotificationType (not a
/// Postgres enum ‚Äî same convention as `Match.surface` / `JoinRequest.status`).
///
/// `body` is a ready-made EN string written at the source event ‚Äî the frontend
/// renders it verbatim (no client templates; global.md ‚Üí "Notification text
/// comes from `body`").
///
/// `matchId` is nullable for future match-less types; in v1 it is always set.
///
/// onDelete Cascade on BOTH relations (unlike JoinRequest/ChatMessage which
/// Restrict on the user to preserve history): notifications are disposable,
/// 30-day-TTL'd per-user rows ‚Äî if a match is hard-deleted (admin, Layer 9) or
/// a user is ever hard-removed, their notifications should vanish, not block.
///
/// Index `(user_id, created_at DESC)` drives the Updates panel query and the
/// `since`-cursor on `GET /api/updates/state`.
model Notification {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  type      String
  matchId   String?   @map("match_id") @db.Uuid
  body      String
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  readAt    DateTime? @map("read_at") @db.Timestamptz(6)

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match? @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

/// Cron idempotency ledger. One row per (match, user, reminder kind) ‚Äî written
/// by Layer 7b crons via `INSERT ... ON CONFLICT DO NOTHING` so a repeated run
/// (process restart, second cron instance, manual replay) never produces a
/// duplicate send. Source of truth: docs/spec/pitchup-spec-match.md ‚Üí "Cron
/// jobs ‚Üí Duplicate guard on retries / process restarts" + app-map ERD ‚Üí
/// ReminderSent.
///
/// `kind` is a `text` column app-validated against `ReminderKind` (same
/// convention as `Notification.type` / `Match.surface` / `JoinRequest.status`).
/// In v1 the only kind is `'morning_reminder'` ‚Äî extension just requires a new
/// constant, no migration.
///
/// Composite PK `(matchId, userId, kind)` is BOTH the uniqueness constraint
/// (drives ON CONFLICT) AND the access index ‚Äî TTL cleanup queries by the
/// leading `matchId` column and reads the PK index. No separate index needed.
///
/// onDelete Cascade on BOTH relations ‚Äî same rationale as Notification: this
/// is a disposable, ‚â§7-day-TTL technical record; if a match or user is hard-
/// removed (admin, Layer 9) the row should evaporate, not block.
///
/// `createdAt @default(now())` exists for debug / audit only ‚Äî the read path
/// keys off match.start_time, not this column. TTL cleanup runs 03:00 Prague
/// daily and removes rows whose match.start_time is > 7 days ago.
model ReminderSent {
  matchId   String   @map("match_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  kind      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([matchId, userId, kind])
  @@map("reminder_sent")
}

/// Ephemeral tombstone for admin hard-deleted matches (Layer 9c).
/// When an admin hard-deletes a match all child rows (JoinRequest, Watch, etc.)
/// cascade, so the global poll (UpdatesStateService) can no longer derive the
/// affected users' relationships. This table stores the affected user IDs for
/// ‚â§24 h so the next poll can emit { action: 'admin_deleted' }. Cleaned by
/// InboxTtlService. No FK on `matchId` ‚Äî the match is gone.
model AdminMatchDeletion {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Stored as TEXT ‚Äî no FK; the match row has been deleted.
  matchId         String   @map("match_id")
  deletedAt       DateTime @default(now()) @map("deleted_at") @db.Timestamptz(6)
  /// Captain + accepted + pending + watching user IDs captured before deletion.
  affectedUserIds String[] @default([]) @map("affected_user_ids") @db.Uuid

  @@index([deletedAt])
  @@map("admin_match_deletions")
}

/// Append-only audit log of admin role/ban actions (Layer 9). Every
/// `promote` / `demote` / `ban` / `unban` taken in `/admin/users` writes one
/// row: who acted, on whom, what, and the required reason text. In v1 the log
/// is NOT surfaced in the UI ‚Äî it is read directly from the DB for appeals and
/// investigations (spec personal.md ‚Üí "Admin role management & safety" ‚Üí
/// "Audit log"; a `/admin/audit` screen is a v1.1 candidate).
///
/// `action` is an app-validated text enum (`promote|demote|ban|unban`), not a
/// Postgres enum ‚Äî same convention as `Notification.type` / `Venue.surface`.
/// `reason` is nullable: `unban` carries no reason (no modal in the spec),
/// the other three require a non-empty reason enforced at the HTTP boundary.
///
/// Both FKs are plain references with NO `onDelete` rule (RESTRICT by default):
/// the audit trail must outlive any cleanup ‚Äî a target user is soft-deleted /
/// banned, never hard-deleted, so the rows are never orphaned. Index on
/// `(target_user_id, created_at DESC)` for the per-user history read.
model AdminAction {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorAdminId String   @map("actor_admin_id") @db.Uuid
  targetUserId String   @map("target_user_id") @db.Uuid
  action       String
  reason       String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor  User @relation("AdminActionActor", fields: [actorAdminId], references: [id])
  target User @relation("AdminActionTarget", fields: [targetUserId], references: [id])

  @@index([targetUserId, createdAt])
  @@map("admin_actions")
}

/// User-submitted abuse report on a match or a player (Layer 9d). Source of
/// truth: docs/spec/pitchup-spec-personal.md ‚Üí "/admin/reports" +
/// docs/spec/pitchup-app-map.md ‚Üí "Report".
///
/// `type` is an app-validated TEXT enum (`match` | `player`) ‚Äî same convention
/// as `Notification.type` / `AdminAction.action`. Exactly one of
/// `targetMatchId` / `targetUserId` is non-null, matching `type` (enforced by
/// `SubmitReportService`, not a DB CHECK ‚Äî app-level validation convention).
///
/// `status` is a per-row TEXT enum (`new` | `reviewed` | `dismissed`). The
/// admin list aggregates per target via a status ladder; the row status is
/// what flips on a `[Review]` action (all `new` ‚Üí `reviewed`) or `[Dismiss]`
/// (that one row ‚Üí `dismissed`).
///
/// **UNIQUE(reporter_id, type, target_match_id, target_user_id)** ‚Äî a repeat
/// report from the same user on the same target is silently deduplicated
/// (INSERT ‚Ä¶ ON CONFLICT DO NOTHING; `SubmitReportService` returns 200 with no
/// new row). Postgres treats NULLs as distinct, so orphaned (`target_*` NULL)
/// rows never collide.
///
/// **Retained indefinitely** ‚Äî no TTL (needed for appeals / violation
/// history, spec app-map ‚Üí Report). `target_match_id` uses `onDelete: SetNull`
/// (NOT Cascade) so an admin hard-delete of a match (Layer 9c) does NOT erase
/// the report trail ‚Äî the row survives with a null target, shown as
/// "[Deleted match]" in the admin list. `reporter_id` / `target_user_id` /
/// `reviewed_by` use RESTRICT: users are only ever soft-deleted, never hard-
/// removed, so these are never orphaned.
///
/// Index `(status, created_at DESC)` drives the `/admin/reports` list scan.
model Report {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporterId    String    @map("reporter_id") @db.Uuid
  type          String
  targetMatchId String?   @map("target_match_id") @db.Uuid
  targetUserId  String?   @map("target_user_id") @db.Uuid
  comment       String    @db.VarChar(500)
  status        String    @default("new")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  reviewedAt    DateTime? @map("reviewed_at") @db.Timestamptz(6)
  reviewedBy    String?   @map("reviewed_by") @db.Uuid

  reporter    User   @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  targetUser  User?  @relation("ReportTargetUser", fields: [targetUserId], references: [id], onDelete: Restrict)
  targetMatch Match? @relation(fields: [targetMatchId], references: [id], onDelete: SetNull)
  reviewer    User?  @relation("ReportReviewer", fields: [reviewedBy], references: [id], onDelete: Restrict)

  @@unique([reporterId, type, targetMatchId, targetUserId])
  @@index([status, createdAt(sort: Desc)])
  @@map("reports")
}

/// Post-match "like a teammate" (Layer 6.X). Composite PK
/// `(matchId, giverId, receiverId)` ‚Äî one like per (giver ‚Üí receiver) pair per
/// match, no separate id, no TTL. Created ONLY on an Ended match by a captain /
/// accepted participant; INSERT ‚Ä¶ ON CONFLICT DO NOTHING makes a repeat tap
/// idempotent (200). Likes are irreversible ‚Äî there is no delete path.
/// Source of truth: docs/spec/pitchup-spec-match.md ‚Üí "Post-match likes",
/// "Per-endpoint checklist" ‚Üí POST /matches/:id/likes + app-map ERD ‚Üí Like.
///
/// `giver` / `receiver` use `onDelete: Restrict` (same as JoinRequest / Watch):
/// users are only ever soft-deleted, never hard-removed, so the like history
/// survives a ban / account deletion (spec ¬ß601 ‚Äî placed likes remain in the
/// DB, the UI just renders the now-unavailable target as `[Removed user]`).
/// `match` uses `onDelete: Cascade` ‚Äî an admin hard-delete of the match (Layer
/// 9c) takes its likes with it, like every other child row.
///
/// The composite PK (leading `match_id`, then `giver_id`) is BOTH the
/// uniqueness constraint (drives ON CONFLICT) AND the access index for every
/// read: per-receiver counts (`WHERE match_id = $1 GROUP BY receiver_id`), the
/// giver's existing likes (`WHERE match_id = $1 AND giver_id = $2`), and the
/// reminder probe (`WHERE giver_id = $1 AND match_id = ANY($2)`). No secondary
/// index needed.
model Like {
  matchId    String   @map("match_id") @db.Uuid
  giverId    String   @map("giver_id") @db.Uuid
  receiverId String   @map("receiver_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  match    Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  giver    User  @relation("LikeGiver", fields: [giverId], references: [id], onDelete: Restrict)
  receiver User  @relation("LikeReceiver", fields: [receiverId], references: [id], onDelete: Restrict)

  @@id([matchId, giverId, receiverId])
  @@map("likes")
}
