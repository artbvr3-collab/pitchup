// PITCHUP — Prisma schema
// Source of truth for the spec: docs/spec/pitchup-app-map.md → "Main entities"
//                              docs/spec/pitchup-spec-global.md → "Authentication", "Slot math", "Field surface", "Cover venue"
//                              docs/spec/pitchup-spec-match.md → "Match states"
// Layers: 1 (User), 2 (Match + Venue read-only), 4 (JoinRequest + Watch), 5 (ChatMessage).
// Subsequent layers grow this file (ChatRead, Notification, Report,
// AdminAction, ReminderSent, Like — see app-map ERD).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Application user. Row is created only when onboarding completes —
/// before that, an OAuth-authenticated visitor has no DB record.
/// See docs/spec/pitchup-spec-global.md → "Onboarding guard".
model User {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  googleSub          String    @unique @map("google_sub")
  email              String
  name               String
  avatarUrl          String    @map("avatar_url")
  contactInfo        String?   @map("contact_info")
  emailNotifications Boolean   @default(true) @map("email_notifications")
  isAdmin            Boolean   @default(false) @map("is_admin")
  banned             Boolean   @default(false)
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  captainMatches Match[]        @relation("MatchCaptain")
  joinRequests   JoinRequest[]
  watches        Watch[]
  chatMessages   ChatMessage[]  @relation("ChatMessageAuthor")

  @@map("users")
}

/// Physical pitch / venue where matches are played. Admin-managed.
/// Fields per docs/spec/pitchup-app-map.md → "Main entities" → Venue row.
/// `surface` is text[] (a venue may offer both grass and hard) — app-level
/// validation against the tokens `grass` / `hard`, not a Postgres enum
/// (see global.md → "Field surface").
/// `cover_id` is a slug into the cover palette, deterministic by venue.id
/// when not explicitly set (see global.md → "Cover venue").
/// `active = false` hides the venue from new-match creation but does not
/// affect existing matches (see personal.md → "/admin/venues").
model Venue {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  address       String
  lat           Float    @db.DoublePrecision
  lng           Float    @db.DoublePrecision
  googleMapsUrl String?  @map("google_maps_url")
  surface       String[] @db.Text
  coverId       String   @map("cover_id") @db.VarChar(40)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  matches Match[]

  @@map("venues")
}

/// A scheduled football match. Captain hosts; players join via JoinRequest
/// (added in Layer 4). Status is computed on-read from `startTime`, `duration`,
/// and `cancelledAt` — there is NO status column (see match.md → "Match states").
///
/// Slot math: `filled = 1 (captain) + captainCrew.length + Σ(accepted JoinRequest)` —
/// canonical formula in global.md → "Slot math". Always via `computeSlots(match)`.
///
/// `coverId` is a snapshot of `venue.coverId` taken at INSERT time. Changing the
/// venue's cover later does NOT propagate to existing matches (intentional
/// denormalization; see app-map.md audit notes + global.md → "Cover venue").
///
/// `captainCrew` is `NOT NULL DEFAULT '{}'` — empty array means an open match
/// with no stub players. `.length` is always safe.
///
/// `surface` validated app-side against `grass` / `hard` (not a Postgres enum;
/// see global.md → "Field surface").
model Match {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  captainId          String    @map("captain_id") @db.Uuid
  venueId            String    @map("venue_id") @db.Uuid
  startTime          DateTime  @map("start_time") @db.Timestamptz(6)
  duration           Int
  totalSpots         Int       @map("total_spots") @db.SmallInt
  price              Int
  surface            String
  studsAllowed       Boolean   @map("studs_allowed")
  fieldBooked        Boolean   @default(false) @map("field_booked")
  description        String?
  descriptionHidden  Boolean   @default(false) @map("description_hidden")
  captainCrew        String[]  @default([]) @map("captain_crew") @db.Text
  cancelledAt        DateTime? @map("cancelled_at") @db.Timestamptz(6)
  cancelReason       String?   @map("cancel_reason")
  cancelReasonHidden Boolean   @default(false) @map("cancel_reason_hidden")
  coverId            String    @map("cover_id") @db.VarChar(40)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  captain      User          @relation("MatchCaptain", fields: [captainId], references: [id])
  venue        Venue         @relation(fields: [venueId], references: [id])
  joinRequests JoinRequest[]
  watches      Watch[]
  chatMessages ChatMessage[]

  @@index([startTime])
  @@index([venueId])
  @@index([captainId])
  @@map("matches")
}

/// A player's request to join a match. UNIQUE(match_id, user_id) — one row per
/// pair. Re-apply after rejected/cancelled/left/kicked is an UPDATE → pending
/// (not a new INSERT). Statuses `accepted` and `pending` count as active; the
/// rest are terminal (history kept for Section Past and re-apply validation).
///
/// `autoReason` is non-null only for system-driven rejects: `match_started`
/// (cron) or `match_cancelled` (mass-reject on captain Cancel). Captain reject
/// uses `auto_reason = NULL`. Spec: match.md → "Player match states",
/// "Auto-rejected pending are distinguishable by auto_reason".
///
/// `guestCount` 0..4 — anonymous +N companions; inseparable from the host
/// (Leave/Kick frees the whole 1+N group). Spec: global.md → "Guests (+N on join)".
model JoinRequest {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  matchId    String   @map("match_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  status     String
  guestCount Int      @default(0) @map("guest_count") @db.SmallInt
  message    String?
  autoReason String?  @map("auto_reason")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([matchId, userId])
  @@index([matchId, status])
  @@index([userId])
  @@map("join_requests")
}

/// "Notify me when a spot opens" flag on a `(user, match)` pair. Composite PK,
/// no separate id. Created only on a full match (backend guard in `POST /watch`,
/// Layer 5+); deleted on Join (same tx as JoinRequest UPSERT), Approve (same tx),
/// and `notify watching` slot-freed sub-operation. Spec: match.md → "Watching
/// logic", app-map ERD → Watch.
model Watch {
  matchId   String   @map("match_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@id([matchId, userId])
  @@index([userId])
  @@map("watches")
}

/// Per-match chat message. Source of truth: docs/spec/pitchup-spec-match.md →
/// "Tab Chat" and docs/spec/pitchup-app-map.md → ChatMessage entity.
///
/// `author_id` uses ON DELETE RESTRICT — messages from banned or deleted users
/// are never physically removed; the render layer resolves the name/avatar and
/// falls back to `[Removed user]` if the profile is gone or banned (match.md §220).
///
/// `deleted_at` enables captain soft-delete (match.md §225 "[Delete]" action).
/// Hard-delete is intentionally omitted: moderation history must survive even
/// when the match is Cancelled, and the captain retains moderation rights.
///
/// Composite index on `(match_id, created_at)` drives both the ordered chat feed
/// and the `since`-cursor used by `GET /api/matches/:id/state?since=ISO`.
model ChatMessage {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  matchId   String    @map("match_id") @db.Uuid
  authorId  String    @map("author_id") @db.Uuid
  text      String    @db.VarChar(2000)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  match  Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  author User  @relation("ChatMessageAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([matchId, createdAt])
  @@map("chat_messages")
}
